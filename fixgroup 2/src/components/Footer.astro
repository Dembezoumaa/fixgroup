---
import { branches, workgebied, site } from '../data/content.js';
---
<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo">
          <span class="logo-mark"><span>FIX</span></span>
          <span class="logo-group" style="color: rgba(255,255,255,0.4)">GROUP</span>
        </a>
        <p>Vier takken, één team. 24/7 bereikbaar vanuit Hilversum, actief in heel Nederland.</p>
        <div style="display: flex; gap: 10px; margin-top: 20px">
          <a href="#" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
          </a>
          <a href="#" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href={`https://wa.me/${site.whatsapp.replace('+', '')}`} aria-label="WhatsApp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.007-.371-.009-.57-.009-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
          </a>
        </div>
      </div>
      <div>
        <h5>Diensten</h5>
        <ul>
          {branches.map((b) => (
            <li><a href={`/diensten/${b.slug}/`}>{b.name}</a></li>
          ))}
          <li><a href="/spoed/" style="color: #FF4655">Spoed 24/7 →</a></li>
        </ul>
      </div>
      <div>
        <h5>Werkgebied</h5>
        <ul>
          {workgebied.slice(0, 5).map((p) => (
            <li><a href={`/werkgebied/${p.toLowerCase()}/`}>{p}</a></li>
          ))}
          <li><a href="/werkgebied/" style="opacity: 0.55">Alle plaatsen →</a></li>
        </ul>
      </div>
      <div>
        <h5>Bedrijf</h5>
        <ul>
          <li><a href="/over-ons/">Over ons</a></li>
          <li><a href="/reviews/">Reviews</a></li>
          <li><a href="/faq/">FAQ</a></li>
          <li><a href="/vacatures/">Vacatures</a></li>
        </ul>
      </div>
      <div>
        <h5>Contact</h5>
        <ul>
          <li><a href={`tel:${site.phoneRaw}`}>{site.phone}</a></li>
          <li><a href={`https://wa.me/${site.whatsapp.replace('+', '')}`}>WhatsApp</a></li>
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><a href="/offerte/">Offerte aanvragen</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="mono" style="color: rgba(255,255,255,0.4)">
        © {new Date().getFullYear()} {site.name} · KvK {site.kvk} · BTW {site.btw}
      </div>
      <div style="display: flex; gap: 20px; font-size: 13px">
        <a href="/privacy/" style="color: rgba(255,255,255,0.4)">Privacy</a>
        <a href="/algemene-voorwaarden/" style="color: rgba(255,255,255,0.4)">Voorwaarden</a>
        <a href="/cookies/" style="color: rgba(255,255,255,0.4)">Cookies</a>
      </div>
    </div>
  </div>
</footer>
