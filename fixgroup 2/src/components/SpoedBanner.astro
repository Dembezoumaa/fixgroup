---
// SpoedBanner: prominente rode attentie-sectie.
// Gebruikt bestaande .spoed-banner styling uit global.css.
// Gebruikt op homepage, hub-pagina's, en diensten met spoed: true.
import { site } from '../data/content.js';

const {
  title = 'Spoed? Bel direct.',
  text = `Lekkage, stroomstoring, verstopping of andere acute schade? Een vakman staat binnen gemiddeld ${site.emergencyResponse} minuten voor uw deur — 24/7, ook weekenden en feestdagen.`,
  ctaText = 'Ook WhatsApp',
} = Astro.props;
---
<section class="sec">
  <div class="wrap">
    <div class="spoed-banner">
      <div>
        <div class="eyebrow" style="color: #fff; opacity: 0.9;">
          <span class="live"></span> 24/7 bereikbaar
        </div>
        <h2 style="margin-top: 12px;">{title}</h2>
        <p>{text}</p>
        <div class="spoed-cta-row">
          <a href={`tel:${site.phoneRaw}`} class="btn btn-white">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Bel {site.phone}
          </a>
          <a href={`https://wa.me/${site.whatsapp.replace('+', '')}`} class="btn btn-dark">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.007-.371-.009-.57-.009-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            </svg>
            {ctaText}
          </a>
        </div>
      </div>
      <div>
        <div class="big-phone">
          <span class="live"></span>
          <span>{site.phone}</span>
        </div>
        <div style="opacity: 0.8; margin-top: 12px; font-size: 14px;">
          Gem. reactietijd: <b>{site.emergencyResponse} min</b> · Dag &amp; nacht bemand
        </div>
      </div>
      <div class="spoed-slab" aria-hidden="true">24/7</div>
    </div>
  </div>
</section>
