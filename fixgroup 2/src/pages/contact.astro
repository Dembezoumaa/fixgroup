---
// Contactpagina · /contact/
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqSection from '../components/FaqSection.jsx';
import { site } from '../data/content.js';
---
<BaseLayout
  title="Contact — direct bereikbaar"
  description={`Contact opnemen met ${site.name}. Bel ${site.phone}, WhatsApp of stuur een bericht. 24/7 bereikbaar vanuit ${site.address.city}.`}
>
  <div class="wrap">
    <nav class="crumb" aria-label="Broodkruimel">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span>Contact</span>
    </nav>
  </div>

  <section class="hub-hero">
    <div class="wrap">
      <div class="hub-hero-grid">
        <div>
          <div class="eyebrow">Contact</div>
          <h1 style="margin-top: 16px;">Direct antwoord,<br />geen wachtrij.</h1>
          <p class="tagline">
            Telefoon of WhatsApp werkt het snelst. We zitten klaar — 24 uur per dag, 7 dagen per week. Liever mailen of langskomen? Dat kan ook.
          </p>
        </div>
        <div>
          <div style="background: var(--ink); color: #fff; border-radius: 14px; padding: 32px;">
            <div class="mono" style="color: rgba(255,255,255,0.5); font-size: 11px; letter-spacing: 0.1em;">SNELSTE WEG</div>
            <div style="font-family: var(--f-mono); font-size: 36px; font-weight: 600; margin-top: 8px; letter-spacing: -0.02em;">
              <a href={`tel:${site.phoneRaw}`} style="color: #fff;">{site.phone}</a>
            </div>
            <div style="color: rgba(255,255,255,0.7); font-size: 13px; margin-top: 8px;">
              24/7 bemand · gem. reactie {site.emergencyResponse} min bij spoed
            </div>
            <div style="margin-top: 24px; display: flex; flex-direction: column; gap: 8px;">
              <a href={`tel:${site.phoneRaw}`} class="btn btn-red btn-lg" style="justify-content: center;">Bel direct →</a>
              <a href={`https://wa.me/${site.whatsapp.replace('+', '')}`} class="btn btn-ghost btn-lg" style="justify-content: center; background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2); color: #fff;">WhatsApp →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="two-col">
        <div class="pane">
          <h3>Bereikbaarheid</h3>
          <ul>
            <li>
              <svg class="ic c" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span><b>Telefoon</b> — <a href={`tel:${site.phoneRaw}`}>{site.phone}</a></span>
            </li>
            <li>
              <svg class="ic c" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.007-.371-.009-.57-.009-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
              <span><b>WhatsApp</b> — <a href={`https://wa.me/${site.whatsapp.replace('+', '')}`}>{site.phone}</a></span>
            </li>
            <li>
              <svg class="ic c" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span><b>E-mail</b> — <a href={`mailto:${site.email}`}>{site.email}</a></span>
            </li>
            <li>
              <svg class="ic c" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span><b>Openingstijden</b> — 24/7, ook feestdagen</span>
            </li>
          </ul>
        </div>
        <div class="pane">
          <h3>Bezoekadres</h3>
          <ul>
            <li>
              <svg class="ic c" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>
                <b>{site.name}</b><br />
                {site.address.street}<br />
                {site.address.postalCode} {site.address.city}
              </span>
            </li>
            <li>
              <svg class="ic c" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>Langskomen op afspraak</span>
            </li>
            <li>
              <svg class="ic c" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>KvK {site.kvk} · BTW {site.btw}</span>
            </li>
          </ul>
          <div style="margin-top: 20px;">
            <a href="/offerte/" class="btn btn-dark btn-sm">Of vraag een offerte aan →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FaqSection client:visible />
</BaseLayout>
