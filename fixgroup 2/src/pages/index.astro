---
// Homepage — alle hoofd-secties van FIX Group in logische volgorde.
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqSection from '../components/FaqSection.jsx';
import ReviewsSection from '../components/ReviewsSection.astro';
import SpoedBanner from '../components/SpoedBanner.astro';
import { branches, site } from '../data/content.js';

// JSON-LD structured data — LocalBusiness
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.name,
  image: `${site.domain}/img/og-default.jpg`,
  url: site.domain,
  telephone: site.phoneRaw,
  email: site.email,
  priceRange: '€€',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    postalCode: site.address.postalCode,
    addressLocality: site.address.city,
    addressCountry: site.address.country,
  },
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '00:00',
    closes: '23:59',
  }],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: site.rating,
    reviewCount: site.reviewCount,
  },
};
---
<BaseLayout structuredData={structuredData}>
  {/* ============ HERO ============ */}
  <section class="hero">
    <div class="wrap">
      <div class="hero-grid">
        <div class="hero-left">
          <div class="hero-eyebrow">
            <span class="live"></span>
            <span class="mono">Nu bereikbaar · gem. {site.emergencyResponse} min</span>
          </div>
          <h1 class="display">
            Vakmannen<br />
            wanneer ú ze<br />
            <span class="red">nodig heeft.</span>
          </h1>
          <p class="hero-lede">
            Loodgieters, elektriciens, schoonmaak en 24/7 service — vier takken, één team.
            Vanuit Hilversum binnen {site.emergencyResponse} minuten ter plaatse in 't Gooi en de Randstad.
          </p>
          <div class="hero-ctas">
            <a href="/offerte/" class="btn btn-red btn-lg">Offerte in 2 min →</a>
            <a href={`tel:${site.phoneRaw}`} class="btn btn-ghost btn-lg">
              Bel {site.phone}
            </a>
          </div>
          <div class="hero-meta">
            <span class="pill">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              VCA &amp; NEN 1010
            </span>
            <span class="pill">
              <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {site.rating.toString().replace('.', ',')}/5 · {site.reviewCount} reviews
            </span>
            <span class="pill">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              24/7, ook feestdagen
            </span>
          </div>
        </div>
        <div class="hero-right">
          <div class="photo-ph">
            <div class="photo-ph-label">FIX-TEAM · HILVERSUM</div>
            <div class="hero-badge">
              <span class="live" style="width: 6px; height: 6px; border-radius: 50%; background: var(--red); display: inline-block; box-shadow: 0 0 0 3px rgba(225,29,46,0.2);"></span>
              LIVE · {site.emergencyResponse} min
            </div>
          </div>
          <div class="hero-stat-card">
            <div class="val"><span class="red">{site.jobsDone.toLocaleString('nl-NL')}+</span></div>
            <div class="lbl">klussen geklaard sinds {new Date().getFullYear() - site.yearsActive}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============ TICKER ============ */}
  <div class="ticker-bar">
    <div class="ticker-inner">
      <span class="ticker-item"><span class="live"></span> Spoed actief · nu bereikbaar</span>
      <span class="ticker-item sep">·</span>
      <span class="ticker-item">Hilversum → Amsterdam → Utrecht → Amersfoort</span>
      <span class="ticker-item sep">·</span>
      <span class="ticker-item"><span class="red">24/7</span> spoeddienst</span>
      <span class="ticker-item sep">·</span>
      <span class="ticker-item">VCA · NEN 1010 · gecertificeerd</span>
    </div>
  </div>

  {/* ============ USP STRIP ============ */}
  <section class="usp-strip">
    <div class="wrap">
      <div class="usp-strip-inner">
        <div class="usp">
          <div class="num">01</div>
          <div class="val"><span class="red">{site.emergencyResponse}</span> min</div>
          <div class="lbl">Gem. reactietijd bij spoed</div>
        </div>
        <div class="usp">
          <div class="num">02</div>
          <div class="val">{site.yearsActive} jaar</div>
          <div class="lbl">Actief in 't Gooi &amp; Randstad</div>
        </div>
        <div class="usp">
          <div class="num">03</div>
          <div class="val">{site.jobsDone.toLocaleString('nl-NL')}+</div>
          <div class="lbl">Klussen succesvol afgerond</div>
        </div>
        <div class="usp">
          <div class="num">04</div>
          <div class="val">{site.rating.toString().replace('.', ',')}/5</div>
          <div class="lbl">Google-beoordeling · {site.reviewCount} reviews</div>
        </div>
      </div>
    </div>
  </section>

  {/* ============ BRANCHES / TABS ============ */}
  <section class="sec branches">
    <div class="wrap">
      <div class="branches-head">
        <div>
          <div class="eyebrow">Vier takken</div>
          <h2 class="h2" style="margin-top: 8px;">Alles onder één dak. Eén aanspreekpunt.</h2>
        </div>
        <a href="/diensten/" class="btn btn-ghost">Alle diensten →</a>
      </div>

      {/* Tabs nav */}
      <div class="tabs">
        {branches.map((b, i) => (
          <a
            href={`/diensten/${b.slug}/`}
            class={`tab ${i === 0 ? 'active' : ''}`}
            style={`--tab-color: ${b.color};`}
          >
            <div class="tab-label">
              <span class="tab-dot"></span>
              <span class="tab-title">{b.short}</span>
              <span class="tab-count">{String(b.services.length).padStart(2, '0')}</span>
            </div>
            <div class="tab-desc">{b.tagline}</div>
          </a>
        ))}
      </div>

      {/* Branch panels — alle 4 onder elkaar zodat geen JS nodig */}
      <div style="margin-top: 24px; display: flex; flex-direction: column; gap: 16px;">
        {branches.map((b) => (
          <div class="branch-panel" style={`--tab-color: ${b.color}; --tab-bg: ${b.tint};`}>
            <div class="branch-panel-l">
              <span class="branch-tag">
                <span style={`width: 6px; height: 6px; border-radius: 50%; background: ${b.color};`}></span>
                {b.name}
              </span>
              <h3>{b.tagline}</h3>
              <p class="branch-panel-desc">{b.desc}</p>
              <div class="branch-services">
                {b.services.slice(0, 6).map((s) => (
                  <a href={`/diensten/${b.slug}/${s.slug}/`}>
                    <span>
                      {s.title}
                      {s.spoed && <span style="color: var(--red); margin-left: 6px; font-size: 10px;">● SPOED</span>}
                    </span>
                    <svg class="arr" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                ))}
              </div>
              <div class="branch-cta">
                <a href={`/diensten/${b.slug}/`} class="btn btn-dark btn-sm">Bekijk tak →</a>
                <a href="/offerte/" class="btn btn-ghost btn-sm">Offerte</a>
              </div>
            </div>
            <div class="branch-panel-r" style={`background: ${b.tint};`}>
              <div style="font-family: var(--f-mono); font-size: 120px; font-weight: 600; letter-spacing: -0.05em; color: rgba(0,0,0,0.08); line-height: 0.9;">
                {String(branches.indexOf(b) + 1).padStart(2, '0')}
              </div>
              <div style="font-size: 14px; color: var(--ink-2); max-width: 240px;">
                {b.services.length} diensten · inzetbaar vanaf morgen
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ POSTCODE / WERKGEBIED CARD ============ */}
  <section class="sec" style="padding-top: 0;">
    <div class="wrap">
      <div class="postcode-card">
        <div>
          <div class="eyebrow" style="color: rgba(255,255,255,0.6);">Werkgebied</div>
          <h3 style="margin-top: 8px;">Werken wij bij u in de buurt?</h3>
          <p>Vanuit Hilversum rijden we dagelijks naar 't Gooi, Amsterdam, Utrecht en Amersfoort. Check uw postcode of bekijk het volledige werkgebied.</p>
          <div class="pc-input">
            <input type="text" placeholder="Uw postcode · bv. 1211 CL" aria-label="Postcode" />
            <a href="/werkgebied/" class="btn btn-red">Check →</a>
          </div>
          <div class="pc-result" style="opacity: 0.55;">
            Tip: of bel {site.phone} — dan horen we direct of we komen.
          </div>
        </div>
        <div class="pc-visual">
          <div style="font-family: var(--f-mono); font-size: 18px; letter-spacing: 0.1em; color: rgba(255,255,255,0.6);">'T GOOI</div>
          <div style="font-family: var(--f-mono); font-size: 54px; font-weight: 600; letter-spacing: -0.02em; color: #fff; margin-top: 12px; line-height: 1;">45&nbsp;min</div>
          <div style="color: rgba(255,255,255,0.6); margin-top: 8px; font-size: 13px;">Gem. reactietijd vanuit Hilversum</div>
        </div>
      </div>
    </div>
  </section>

  {/* ============ REVIEWS ============ */}
  <ReviewsSection />

  {/* ============ SPOED BANNER ============ */}
  <SpoedBanner />

  {/* ============ OFFERTE MINI ============ */}
  <section class="sec">
    <div class="wrap">
      <div class="offerte-mini">
        <div>
          <div class="eyebrow">Offerte</div>
          <h2 style="margin-top: 8px;">In 2 minuten een vrijblijvende offerte.</h2>
          <p>Beschrijf kort wat u zoekt — wij bellen u dezelfde werkdag terug met een eerlijke prijsindicatie. Geen kleine lettertjes, geen verplichtingen.</p>
          <ul class="offerte-perks" style="list-style: none; padding: 0;">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Reactie binnen 4 werkuren
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Vaste prijs, geen verrassingen
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Garantie op alle werkzaamheden
            </li>
          </ul>
        </div>
        <div>
          <div style="background: var(--card); border: 1px solid var(--line); border-radius: 12px; padding: 24px;">
            <div class="mono" style="color: var(--ink-3); margin-bottom: 16px;">Snel starten →</div>
            <div style="display: flex; flex-direction: column; gap: 12px;">
              <a href="/offerte/" class="btn btn-red btn-lg" style="justify-content: center;">
                Offerteformulier invullen →
              </a>
              <a href={`tel:${site.phoneRaw}`} class="btn btn-dark btn-lg" style="justify-content: center;">
                Liever bellen: {site.phone}
              </a>
              <a href={`https://wa.me/${site.whatsapp.replace('+', '')}`} class="btn btn-ghost btn-lg" style="justify-content: center;">
                Of via WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============ FAQ ============ */}
  <FaqSection client:visible />
</BaseLayout>
